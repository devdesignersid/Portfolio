{
  "name": "portfolio",
  "version": "0.1.0",
  "description": "Sid's personal website",
  "main": "src/index.js",
  "scripts": {
    "build": "gatsby build",
    "develop": "cross-env GATSBY_GRAPHQL_IDE=playground gatsby develop",
    "format": "prettier --write src/**/*.{js,jsx}",
    "start": "npm run develop",
    "server": "gatsby serve",
    "cy:open": "cypress open",
    "prepare": "husky install",
    "test": "jest"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devdesignersid/portfolio.git"
  },
  "keywords": [
    "Portfolio",
    "Siddharth.S.Kumar"
  ],
  "author": "Siddharth S Kumar",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/devdesignersid/portfolio/issues"
  },
  "homepage": "https://github.com/devdesignersid/portfolio#readme",
  "dependencies": {
    "@artsy/fresnel": "^1.7.0",
    "@emotion/core": "^11.0.0",
    "@emotion/react": "^11.4.0",
    "@emotion/styled": "^11.3.0",
    "emotion-normalize": "^11.0.1",
    "framer-motion": "^4.1.17",
    "gatsby": "^3.7.1",
    "gatsby-plugin-emotion": "^6.7.1",
    "gatsby-plugin-image": "^1.7.1",
    "gatsby-plugin-sharp": "^3.7.1",
    "gatsby-source-filesystem": "^3.7.1",
    "gatsby-transformer-sharp": "^3.7.1",
    "prop-types": "^15.7.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@testing-library/cypress": "^7.0.6",
    "@testing-library/react": "^11.2.7",
    "babel-jest": "^27.0.2",
    "babel-preset-gatsby": "^1.7.1",
    "cypress": "^7.5.0",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "^7.28.0",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-config-node": "^4.1.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-cypress": "^2.11.3",
    "eslint-plugin-import": "^2.23.4",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-prettier": "^3.4.0",
    "eslint-plugin-react": "^7.24.0",
    "husky": "^6.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^27.0.4",
    "lint-staged": "^11.0.0",
    "prettier": "^2.3.1"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
